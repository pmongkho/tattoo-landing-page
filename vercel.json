{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm --prefix angular-client ci && npm --prefix angular-client run build",
  "outputDirectory": "angular-client/dist/tattoo-landing-client/browser",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
